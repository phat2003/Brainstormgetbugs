@using Microsoft.AspNetCore.Identity
@model IEnumerable<Idea>
@inject UserManager<IdentityUser> UserManager

<div class="container py-4" style="max-width: 600px;">
    <h2 class="mb-4 text-primary">Bảng Tin Ý Tưởng</h2>
    @foreach (var idea in Model)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="d-flex align-items-center mb-2">
                    <img src="https://ui-avatars.com/api/?name=@idea.ApplicationUser.UserName&background=random"
                         class="rounded-circle me-2" width="40" height="40" alt="avatar" />
                    <div>
                        <strong>@idea.ApplicationUser.UserName</strong><br />
                        <small class="text-muted">@idea.CreatedDate.ToString("dd/MM/yyyy")</small>
                    </div>
                </div>
                <p class="card-text fs-5">@idea.Text</p>
                <div class="mb-2">
                    <span class="badge bg-secondary">@idea.Category.Name</span>
                    <span class="badge bg-info text-dark">@idea.Topic.Name</span>
                </div>
                <div>
                    <button class="btn btn-outline-primary btn-sm me-2" disabled>
                        <i class="bi bi-hand-thumbs-up"></i> Thích
                    </button>
                    <button class="btn btn-outline-primary btn-sm me-2" disabled>
                        <i class="bi bi-hand-thumbs-up"></i> Không thích
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" disabled>
                        <i class="bi bi-chat-dots"></i> Bình luận
                    </button>

                    <form asp-action="Views" method="post">
                        <input type="hidden" name="IdeaId" value="@idea.Id" />

                        <input type="hidden" name="VisitTime" value="1" />

                        <button type="submit" class="btn btn-danger">
                            Views
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
