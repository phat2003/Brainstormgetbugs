@using Microsoft.AspNetCore.Identity
@using Brainstorm.Utility

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    // 1. Lấy danh sách các tài khoản đang có vai trò là Admin
    var adminUsers = await UserManager.GetUsersInRoleAsync(SD.Role_User_Admin);

    // 2. Kiểm tra xem danh sách có phần tử nào không (true nếu đã có ít nhất 1 admin)
    bool hasAdmin = adminUsers.Any();
}

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
        @if (User.Identity.IsAuthenticated && User.IsInRole(SD.Role_User_Admin))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
            </li>
        }
    <li class="nav-item">
        <a id="manage" class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @UserManager.GetUserName(User)!</a>
    </li>
        
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="nav-link btn btn-link text-dark border-0">Logout</button>
        </form>
    </li>
}
else
{
    // 3. Chỉ hiển thị nút Register nếu chưa có Admin (!hasAdmin)
    @if (!hasAdmin)
    {
        <li class="nav-item">
            <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>

}
</ul>
